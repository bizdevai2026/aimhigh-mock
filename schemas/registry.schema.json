{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gradeblaze/registry",
  "title": "Content registry",
  "description": "The single source of truth for subjects + topics + year-level availability. The runtime stops deriving these from question payloads — metadata lives here. Adding a Year 8 topic = appending to this file plus shipping the questions.",
  "type": "object",
  "required": ["version", "year_levels", "subjects", "topics"],
  "properties": {
    "version":     { "type": "integer", "minimum": 1 },
    "generatedAt": { "type": "string" },
    "year_levels": {
      "type": "array",
      "items": { "type": "integer", "minimum": 7, "maximum": 13 },
      "minItems": 1
    },
    "subjects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id":   { "type": "string", "enum": ["science", "maths", "english", "french", "history", "geography", "computing"] },
          "name": { "type": "string", "minLength": 1 },
          "tone": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
        }
      }
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "subject", "name", "year_levels_available"],
        "properties": {
          "id":       { "type": "string", "pattern": "^[a-z0-9\\-]+$" },
          "subject":  { "type": "string", "enum": ["science", "maths", "english", "french", "history", "geography", "computing"] },
          "name":     { "type": "string", "minLength": 1 },
          "subtitle": { "type": "string" },
          "year_levels_available": {
            "type": "array",
            "items": { "type": "integer", "minimum": 7, "maximum": 13 },
            "minItems": 1
          },
          "order":            { "type": "integer", "minimum": 0 },
          "prerequisite_topic_ids": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
