{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gradeblaze/learning",
  "title": "Learning entry",
  "description": "One LEARN topic — read-before-test explainer with sections, callouts, examples, quickfacts.",
  "type": "object",
  "required": ["subject", "topic", "title", "sections"],
  "properties": {
    "subject":     { "type": "string", "enum": ["science", "maths", "english", "french", "history", "geography", "computing"] },
    "topic":       { "type": "string", "pattern": "^[a-z0-9\\-]+$" },
    "year_level":  { "type": "integer", "minimum": 7, "maximum": 13 },
    "title":       { "type": "string", "minLength": 3 },
    "subtitle":    { "type": "string" },
    "readTimeMin": { "type": "integer", "minimum": 1, "maximum": 30 },
    "visual":      { "type": "string", "pattern": "^[a-z0-9\\-]+$" },
    "status":      { "type": "string", "enum": ["draft", "live", "retired"] },
    "sections":    {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/section" }
    },
    "tips":        { "type": "array", "items": { "type": "string" } }
  },
  "definitions": {
    "section": {
      "type": "object",
      "description": "A section can mix any of: heading / body / list / visual / callout / example / quickfact.",
      "properties": {
        "heading":   { "type": "string" },
        "body":      { "type": "string" },
        "list":      { "type": "array", "items": { "type": "string" } },
        "visual":    { "type": "string", "pattern": "^[a-z0-9\\-]+$" },
        "callout":   {
          "type": "object",
          "required": ["body"],
          "properties": {
            "tone":  { "type": "string", "enum": ["tip", "warn", "note"] },
            "title": { "type": "string" },
            "body":  { "type": "string", "minLength": 1 }
          }
        },
        "example":   {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "intro": { "type": "string" },
            "steps": { "type": "array", "items": { "type": "string" } },
            "outro": { "type": "string" }
          }
        },
        "quickfact": {
          "type": "object",
          "required": ["value", "label"],
          "properties": {
            "value": { "type": "string", "minLength": 1 },
            "label": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
